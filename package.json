{
  "name": "sectrai-finans",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api": "node server/index.mjs",
    "start": "node server/index.mjs",
    "typecheck": "tsc -b --pretty false",
    "build": "vite build",
    "lint": "oxlint",
