{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023", "lib": ["ES2023", "DOM"], "module": "esnext", "types": ["vite/client", "node"],
    "moduleResolution": "bundler", "verbatimModuleSyntax": true, "moduleDetection": "force", "noEmit": true, "jsx": "react-jsx",
    "baseUrl": ".", "paths": { "@/*": ["src/*"], "@shared/*": ["shared/*"] }, "ignoreDeprecations": "6.0",
    "skipLibCheck": true, "noUnusedLocals": true, "noUnusedParameters": true, "erasableSyntaxOnly": true, "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "shared", "middleware.ts"]
}
